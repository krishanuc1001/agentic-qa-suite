# Copy this file to `.streamlit/secrets.toml` for LOCAL development,
# OR paste the contents into the "Secrets" panel when deploying to
# Streamlit Community Cloud / Hugging Face Spaces.
#
# NEVER commit the real secrets.toml -- it is gitignored.

# --- Required: pick at least one LLM provider ---
GROQ_API_KEY = "your-groq-key-here"
GEMINI_API_KEY = "your-gemini-key-here"

# --- Optional: enables Agent 3 web-grounding & autonomous tool loop ---
TAVILY_API_KEY = "your-tavily-key-here"

# --- Optional: enable LangSmith tracing of every agent + tool call ---
# (Auto-detected by src/langgraphAgenticAI/observability/setup.py)
# LANGCHAIN_API_KEY = "your-langsmith-key-here"
# LANGCHAIN_PROJECT = "qa-intelligence-suite"

# --- Optional: turn on LangGraph in-memory checkpointing (Gap #3) ---
# Lets multi-step runs be resumed/inspected via thread_id.
# LANGGRAPH_CHECKPOINT_ENABLED = "1"

# --- Optional: password-gate this deployment (Gap #8) ---
# When set, visitors must enter this exact value before the app loads.
# APP_PASSWORD = "choose-a-strong-passphrase"
